# Gas Town crew identity for lora_forge/crew/forge
# Generated from sfgastown/mayor/rig/scripts/crew-envrc-template.sh
# Activates automatically via direnv when entering this directory.

RIG="lora_forge"
CREW="forge"
AGENT="claudecode-nvim"

export GT_ROLE="${RIG}/crew/${CREW}"
export GT_RIG="${RIG}"
export GT_CREW="${CREW}"
export GT_AGENT="${AGENT}"
export BD_ACTOR="${RIG}/crew/${CREW}"
export BEADS_AGENT_NAME="${RIG}/${CREW}"
export GIT_AUTHOR_NAME="${CREW}"
export GT_ROOT="/home/ubuntu/gt"

# OTel telemetry propagation
if [ -n "${GT_OTEL_METRICS_URL:-}" ]; then
  export CLAUDE_CODE_ENABLE_TELEMETRY=1
  export OTEL_METRICS_EXPORTER=otlp
  export OTEL_METRIC_EXPORT_INTERVAL=1000
  export OTEL_EXPORTER_OTLP_METRICS_ENDPOINT="${GT_OTEL_METRICS_URL}"
  export OTEL_EXPORTER_OTLP_METRICS_PROTOCOL="http/protobuf"
  export OTEL_RESOURCE_ATTRIBUTES="gt.role=${GT_ROLE},gt.rig=${GT_RIG},gt.agent=${GT_CREW},gt.harness=${GT_AGENT}"
fi
